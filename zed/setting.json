// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed //
// To see all of Zed"s default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "git_panel": {
    "sort_by_path": true
  },
  "agent_servers": {
    "claude": {
      "default_mode": "acceptEdits"
    }
  },
  "ssh_connections": [
    {
      "host": "matcher_redash",
      "projects": [
        {
          "paths": [
            "/home/redash/redash/docker-compose.yml"
          ]
        }
      ]
    },
    {
      "host": "analytics",
      "projects": [
        {
          "paths": [
            "/home/k.miyoshi/analytics_container"
          ]
        }
      ]
    }
  ],
  "edit_predictions": {
    "disabled_globs": [],
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": true
  },
  "features": {
    "edit_prediction_provider": "copilot"
    // "edit_prediction_provider": "zed"
  },
  "agent": {
    "default_width": 640.0,
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4"
    },
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    }
  },
  "project_panel": {
    "folder_icons": true,
    "file_icons": true
  },
  "icon_theme": "Catppuccin Mocha",
  "agent_buffer_font_size": 16.0,
  "agent_ui_font_size": 16.0,
  "confirm_quit": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "unnecessary_code_fade": 0.6,
  "vim_mode": true,
  "buffer_font_size": 16,
  "buffer_font_family": "Source Han Code JP",
  "tab_size": 2,
  "format_on_save": "off",
  "show_whitespaces": "all",
  "experimental.theme_overrides": {
    // コメントを灰色のイタリック体に変更
    "syntax": {
      "comment": {
        "font_style": "italic",
        "color": "#808080"
      },
      "comment.doc": {
        "font_style": "italic",
        "color": "#808080"
      }
    }
  },
  "theme": {
    "mode": "system",
    "light": "Ayu Mirage",
    "dark": "One Dark"
  },
  "languages": {
    "JavaScript": {
      "language_servers": [ "vtsls", "eslint" ],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "colorize_brackets": true
    },
    "TypeScript": {
      "colorize_brackets": true
    },
    "Dart": {
      "colorize_brackets": true,
    },
    "Vue.js": {
      "colorize_brackets": true,
      "language_servers": [ "vtsls", "eslint", "emmet-language-server" ]
      // "language_servers": [ "vtsls", "eslint" ]
      // "language_servers": [ "vtsls", "scss-lsp" ]
      // "language_servers": [ "vtsls", "emmet-language-server" ]
      // "language_servers": [ "vtsls", "vue-language-server" ]
    },
    "Ruby": {
      "language_servers": [ "solargraph", "typos", "!ruby-lsp" ]
    }
  },
  "lsp": {
    // TypeScript + Vue
    "vtsls": {
      "settings": {
        "vtsls": {
          "tsserver": {
            "globalPlugins": [
              {
                "name": "@vue/typescript-plugin",
                "location": "~/.local/share/zed/extensions/work/vue/node_modules/@vue/language-server",
                "languages": ["vue.js"],
                "configNamespace": "typescript",
                "enableForWorkspaceTypeScriptVersions": true
              }
            ]
          }
        }
      }
    },
    "vue-language-server": {
      "initialization_options": {
        "vue": {
          "hybridMode": false
        }
      }
    },
    "eslint": {
      "settings": {
        // "shortenToSingleLine": true
      }
    },
    "solargraph": {
      "settings": {
        "rubocop": {
          "enabled": false
        },
      }
    },
    "typos": {
      "initialization_options": {
        "config": ".typos.toml",
        "diagnosticSeverity": "Information",
        "logLevel": "info"
      }
    }
    // "emmet-language-server": {
    //   "settings": {
    //     "languages": ["Vue.js","TSX", "HTML", "CSS", "ERB", "JavaScript"]
    //   }
    // }
  },
  "collaboration_panel": {
    // collaborationは使用しないので非表示
    "button": false
  },
  // "chat_panel": {
  //   // chatは使用しないので非表示
  //   "button": "never"
  // },
  "notification_panel": {
    // notificationは使用しないので非表示
    "button": false
  },
  "outline_panel": {
    // outlineは使用しないので非表示
    "button": false
  },
  "debugger": {
    // debuggerは使用しないので非表示
    "button": false
  },
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": true
  },
  "tabs": {
    "file_icons": true
  },
  "extend_comment_on_newline": false,
  "snippet_sort_order": "bottom",
  "minimap": {
    "show": "never"
  },
  "diagnostics": {
    "inline": {
      // rubyのsolargraphの警告が多いので非表示
      // "enabled": true
    }
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  }
}
